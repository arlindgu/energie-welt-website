---
import { Icon } from "astro-icon/components"

interface Props {
  variant?: "primary" | "dark" | "light"
  href?: string
  type?: "button" | "submit" | "reset"
  disabled?: boolean
  [key: string]: unknown
}

const {
  variant = "primary",
  href,
  type = "button",
  disabled,
  ...rest
} = Astro.props
const Tag = href ? "a" : "button"

const variants = {
  primary:
    "bg-brand inline-flex items-center rounded-full px-4 py-3 hover:bg-background/90 transition-colors disabled:bg-background/10 disabled:text-background/50 disabled:cursor-not-allowed",
  dark: "bg-foreground inline-flex items-center text-background rounded-full px-4 py-3 hover:bg-foreground/90 transition-colors disabled:bg-foreground/10 disabled:text-foreground/50 disabled:cursor-not-allowed",
  light:
    "bg-background inline-flex items-center text-foreground rounded-full px-4 py-3 hover:bg-background/90 transition-colors disabled:bg-background/10 disabled:text-background/50 disabled:cursor-not-allowed",
}

const classes = variants[variant]
---

<Tag {...rest} href={href} type={href ? undefined : type} disabled={disabled} class={`${classes} group`}>
  <slot />
</Tag>
