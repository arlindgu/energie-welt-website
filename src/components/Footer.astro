---
import { site } from "@/config/site"
import Logo from "/logo_light.svg?raw"
---

<footer class="overflow-hidden bg-foreground px-6 text-background">
  <div class="mx-auto max-w-6xl pt-20 pb-8">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      <div class="bg-foreground">
        <a href="/" class="inline-flex h-6 items-start [&>svg]:h-full [&>svg]:w-auto">
          <Fragment set:html={Logo} />
        </a>
        <p class="text-sm leading-relaxed text-background/50">
          {site.description}
        </p>
      </div>

      <div class="bg-foreground">
        <p
          class="text-brand mb-6 text-xs font-semibold tracking-widest uppercase"
        >
          Navigation
        </p>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href="/#about"
              class="text-sm text-background/60 transition-colors hover:text-background"
              >Über uns</a
            >
          </li>
          <li>
            <a
              href="/#services"
              class="text-sm text-background/60 transition-colors hover:text-background"
              >Leistungen</a
            >
          </li>
          <li>
            <a
              href="/offerte"
              class="text-sm text-background/60 transition-colors hover:text-background"
              >Offerte</a
            >
          </li>
          <li>
            <a
              href="/impressum"
              class="text-sm text-background/60 transition-colors hover:text-background"
              >Impressum</a
            >
          </li>
          <li>
            <a
              href="/datenschutz"
              class="text-sm text-background/60 transition-colors hover:text-background"
              >Datenschutz</a
            >
          </li>
        </ul>
      </div>

      <div class="bg-foreground">
        <p
          class="text-brand mb-6 text-xs font-semibold tracking-widest uppercase"
        >
          Kontakt
        </p>
        <ul class="flex flex-col gap-3">
          <li class="text-sm text-background/60">
            {site.legal.responsible}
          </li>
          <li>
            <a
              href={`mailto:${site.contact.email}`}
              class="text-sm break-all text-background/60 transition-colors hover:text-background"
            >
              {site.contact.email}
            </a>
          </li>
          <li>
            <a
              href={site.contact.phoneHref}
              class="text-sm text-background/60 transition-colors hover:text-background"
            >
              {site.contact.phone}
            </a>
          </li>

          <li class="text-sm text-background/60">
            {site.address.street}<br />
            {site.address.city}<br />
            {site.address.country}
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-px flex flex-col items-center justify-between gap-4 pt-8 sm:flex-row"
    >
      <p class="text-xs text-background/30">
        © {new Date().getFullYear()}
        {site.legal.company}. Alle Rechte vorbehalten.
      </p>
    </div>
  </div>
</footer>
