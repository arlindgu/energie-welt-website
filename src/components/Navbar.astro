---
import { site } from "@/config/site"
import Button from "@/components/Button.astro"
import Logo from "/logo_light.svg?raw"
---

<header class="sticky top-0 z-50 bg-background px-6">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between">
    <a href="/">
      <Fragment set:html={Logo} class="block h-7 w-auto" />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/#about"
        class="text-muted-foreground text-sm transition-colors hover:text-foreground"
        >Über uns</a
      >
      <a
        href="/#services"
        class="text-muted-foreground text-sm transition-colors hover:text-foreground"
        >Leistungen</a
      >
      <a
        href="/kontakt"
        class="text-muted-foreground text-sm transition-colors hover:text-foreground"
        >Kontakt</a
      >
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden md:inline-flex">
        <Button variant="primary" href="/offerte">Offerte einholen</Button>
      </div>

      <button
        id="menu-toggle"
        class="flex flex-col gap-1.5 p-1 md:hidden"
        aria-label="Menü öffnen"
      >
        <span class="block h-0.5 w-6 bg-foreground transition-all"></span>
        <span class="block h-0.5 w-6 bg-foreground transition-all"></span>
        <span class="block h-0.5 w-6 bg-foreground transition-all"></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="border-border flex hidden flex-col gap-4 border-t bg-background py-4 md:hidden"
  >
    <a
      href="/#about"
      class="text-muted-foreground py-2 text-sm transition-colors hover:text-foreground"
      >Über uns</a
    >
    <a
      href="/#services"
      class="text-muted-foreground py-2 text-sm transition-colors hover:text-foreground"
      >Leistungen</a
    >
    <a
      href="/kontakt"
      class="text-muted-foreground py-2 text-sm transition-colors hover:text-foreground"
      >Kontakt</a
    >
    <Button variant="primary" href="/offerte"> Offerte einholen </Button>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")
  const menu = document.getElementById("mobile-menu")
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden")
  })
</script>
