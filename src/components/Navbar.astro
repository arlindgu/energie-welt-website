---
import { site } from "@/config/site"
import LogoLight from "/logo_light.svg?raw"
import LogoDark from "/logo_dark.svg?raw"
---

<header
  id="site-header"
  class="fixed inset-x-0 z-50 bg-black/20 px-6 backdrop-blur-md transition-[background-color] duration-300"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between">
    <a href="/">
      <span id="logo-light" class="block"><Fragment set:html={LogoDark} /></span>
      <span id="logo-dark" class="hidden"><Fragment set:html={LogoLight} /></span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/#about"
        class="nav-link text-sm text-white/70 transition-colors hover:text-white"
        >Über uns</a
      >
      <a
        href="/#services"
        class="nav-link text-sm text-white/70 transition-colors hover:text-white"
        >Leistungen</a
      >
      <a
        href="/offerte"
        class="nav-link text-sm text-white/70 transition-colors hover:text-white"
        >Offerte</a
      >
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden md:inline-flex">
        <a href="/offerte" class="btn-primary">Offerte einholen</a>
      </div>

      <button
        id="menu-toggle"
        class="flex flex-col gap-1.5 p-1 md:hidden"
        aria-label="Menü öffnen"
      >
        <span class="hamburger-line block h-0.5 w-6 bg-white transition-all"></span>
        <span class="hamburger-line block h-0.5 w-6 bg-white transition-all"></span>
        <span class="hamburger-line block h-0.5 w-6 bg-white transition-all"></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="flex hidden flex-col gap-4 border-t border-white/10 bg-black py-4 md:hidden"
  >
    <a
      href="/#about"
      class="mobile-link py-2 text-sm text-white/70 transition-colors hover:text-white"
      >Über uns</a
    >
    <a
      href="/#services"
      class="mobile-link py-2 text-sm text-white/70 transition-colors hover:text-white"
      >Leistungen</a
    >
    <a
      href="/offerte"
      class="mobile-link py-2 text-sm text-white/70 transition-colors hover:text-white"
      >Offerte</a
    >
    <a href="/offerte" class="btn-primary">Offerte einholen</a>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")
  const logoLight = document.getElementById("logo-light")
  const logoDark = document.getElementById("logo-dark")
  const navLinks = document.querySelectorAll(".nav-link")
  const hamburgerLines = document.querySelectorAll(".hamburger-line")
  const mobileMenu = document.getElementById("mobile-menu")
  const mobileLinks = document.querySelectorAll(".mobile-link")

  const toggle = document.getElementById("menu-toggle")
  toggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden")
  })

  function setScrolled(scrolled: boolean) {
    if (scrolled) {
      header?.classList.remove("bg-black/20", "backdrop-blur-md")
      header?.classList.add("bg-white")
      logoLight?.classList.add("hidden")
      logoDark?.classList.remove("hidden")
      mobileMenu?.classList.remove("bg-black", "border-white/10")
      mobileMenu?.classList.add("bg-white", "border-border")
    } else {
      header?.classList.remove("bg-white")
      header?.classList.add("bg-black/20", "backdrop-blur-md")
      logoDark?.classList.add("hidden")
      logoLight?.classList.remove("hidden")
      mobileMenu?.classList.remove("bg-white", "border-border")
      mobileMenu?.classList.add("bg-black", "border-white/10")
    }

    navLinks.forEach((link) => {
      link.classList.toggle("text-white/70", !scrolled)
      link.classList.toggle("hover:text-white", !scrolled)
      link.classList.toggle("text-muted-foreground", scrolled)
      link.classList.toggle("hover:text-foreground", scrolled)
    })

    hamburgerLines.forEach((line) => {
      line.classList.toggle("bg-white", !scrolled)
      line.classList.toggle("bg-foreground", scrolled)
    })

    mobileLinks.forEach((link) => {
      link.classList.toggle("text-white/70", !scrolled)
      link.classList.toggle("hover:text-white", !scrolled)
      link.classList.toggle("text-muted-foreground", scrolled)
      link.classList.toggle("hover:text-foreground", scrolled)
    })
  }

  const heroEl = document.getElementById("hero")

  if (!heroEl) {
    setScrolled(true)
  } else {
    const observer = new IntersectionObserver(
      ([entry]) => setScrolled(!entry.isIntersecting),
      { threshold: 0 },
    )
    observer.observe(heroEl)
  }
</script>
