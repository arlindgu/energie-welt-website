---
import { site } from "@/config/site"
import LogoLight from "/logo_light.svg?raw"
import LogoDark from "/logo_dark.svg?raw"
---

<header
  id="navbar-shell"
  class="fixed inset-x-0 top-10 z-50 px-10 transition-[top,padding] duration-300"
>
  <nav
    id="site-header"
    class="mx-auto flex h-16 max-w-5xl items-center justify-between rounded-full bg-white pl-6 pr-2 transition-[background-color,max-width] duration-300"
  >
    <a href="/" class="[&_svg]:h-6 [&_svg]:w-auto">
      <span id="logo-light" class="hidden"><Fragment set:html={LogoDark} /></span>
      <span id="logo-dark" class="block"><Fragment set:html={LogoLight} /></span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/#about"
        class="nav-link text-sm text-muted-foreground transition-colors hover:text-foreground"
        >Über uns</a
      >
      <a
        href="/#services"
        class="nav-link text-sm text-muted-foreground transition-colors hover:text-foreground"
        >Leistungen</a
      >
      <a
        href="/offerte"
        class="nav-link text-sm text-muted-foreground transition-colors hover:text-foreground"
        >Offerte</a
      >
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden md:inline-flex">
        <a href="/offerte" class="btn-primary">Offerte einholen</a>
      </div>

      <button
        id="menu-toggle"
        class="flex flex-col gap-1.5 p-1 md:hidden mr-4"
        aria-label="Menü öffnen"
      >
        <span class="hamburger-line block h-0.5 w-6 bg-foreground transition-all"></span>
        <span class="hamburger-line block h-0.5 w-6 bg-foreground transition-all"></span>
        <span class="hamburger-line block h-0.5 w-6 bg-foreground transition-all"></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="mx-auto mt-2 flex hidden max-w-6xl flex-col gap-4 rounded-2xl bg-white px-6 py-4 md:hidden"
  >
    <a
      href="/#about"
      class="mobile-link py-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >Über uns</a
    >
    <a
      href="/#services"
      class="mobile-link py-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >Leistungen</a
    >
    <a
      href="/offerte"
      class="mobile-link py-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >Offerte</a
    >
    <a href="/offerte" class="btn-primary">Offerte einholen</a>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")
  const navbarShell = document.getElementById("navbar-shell")
  const logoLight = document.getElementById("logo-light")
  const logoDark = document.getElementById("logo-dark")
  const navLinks = document.querySelectorAll(".nav-link")
  const hamburgerLines = document.querySelectorAll(".hamburger-line")
  const mobileMenu = document.getElementById("mobile-menu")
  const mobileLinks = document.querySelectorAll(".mobile-link")

  const toggle = document.getElementById("menu-toggle")
  toggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden")
  })

  document.querySelectorAll("#mobile-menu a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden")
    })
  })

  function setScrolled(scrolled: boolean) {
    if (scrolled) {
      header?.classList.remove("bg-white", "max-w-5xl")
      header?.classList.add("bg-black", "max-w-6xl")
      navbarShell?.classList.remove("top-10", "px-10")
      navbarShell?.classList.add("top-4", "px-6")
      logoDark?.classList.add("hidden")
      logoLight?.classList.remove("hidden")
      mobileMenu?.classList.remove("bg-white", "border-border")
      mobileMenu?.classList.add("bg-black", "border-white/10")
    } else {
      header?.classList.remove("bg-black", "max-w-6xl")
      header?.classList.add("bg-white", "max-w-5xl")
      navbarShell?.classList.remove("top-4", "px-6")
      navbarShell?.classList.add("top-10", "px-10")
      logoLight?.classList.add("hidden")
      logoDark?.classList.remove("hidden")
      mobileMenu?.classList.remove("bg-black", "border-white/10")
      mobileMenu?.classList.add("bg-white", "border-border")
    }

    navLinks.forEach((link) => {
      link.classList.toggle("text-white/70", scrolled)
      link.classList.toggle("hover:text-white", scrolled)
      link.classList.toggle("text-muted-foreground", !scrolled)
      link.classList.toggle("hover:text-foreground", !scrolled)
    })

    hamburgerLines.forEach((line) => {
      line.classList.toggle("bg-white", scrolled)
      line.classList.toggle("bg-foreground", !scrolled)
    })

    mobileLinks.forEach((link) => {
      link.classList.toggle("text-white/70", scrolled)
      link.classList.toggle("hover:text-white", scrolled)
      link.classList.toggle("text-muted-foreground", !scrolled)
      link.classList.toggle("hover:text-foreground", !scrolled)
    })
  }

  const heroEl = document.getElementById("hero")

  if (!heroEl) {
    setScrolled(true)
  } else {
    const observer = new IntersectionObserver(
      ([entry]) => setScrolled(!entry.isIntersecting),
      { threshold: 0 },
    )
    observer.observe(heroEl)
  }
</script>
