<section id="about" class="w-full bg-background py-28 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <div>
            <h2>
                Wir gestalten die<br />Energiewende mit
            </h2>
            <p class="text-muted-foreground leading-relaxed mb-5">
                EnergieWelt ist Ihr Partner für moderne, nachhaltige Energielösungen.
                Seit über einem Jahrzehnt helfen wir Privathaushalten und Unternehmen,
                ihren Energieverbrauch zu optimieren und auf erneuerbare Quellen umzustellen.
            </p>
            <p class="text-muted-foreground leading-relaxed mb-10">
                Unser Team aus erfahrenen Energieberatern und Ingenieuren steht Ihnen
                bei jedem Schritt zur Seite – von der ersten Beratung bis zur vollständigen
                Installation und darüber hinaus.
            </p>

            <hr class="mb-10 border-border" />

            <div class="flex flex-col sm:flex-row gap-10">
                <div>
                    <p class="font-heading text-4xl font-semibold">15+</p>
                    <p class="text-sm text-muted-foreground mt-1">Jahre Erfahrung</p>
                </div>
                <div>
                    <p class="font-heading text-4xl font-semibold">100+</p>
                    <p class="text-sm text-muted-foreground mt-1">Projekte</p>
                </div>
                <div>
                    <p class="font-heading text-4xl font-semibold">99.8%</p>
                    <p class="text-sm text-muted-foreground mt-1">Kundenzufriedenheit</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="rounded-2xl aspect-square">
                <img src="/solar-1.jpg" alt="Solaranlage" class="w-full h-full object-cover rounded-2xl" />
            </div>
            <div class="rounded-2xl aspect-square mt-8">
                <img src="/solar-2.jpg" alt="Solaranlage" class="w-full h-full object-cover rounded-2xl" />
            </div>
            <div class="ounded-2xl col-span-2 h-40">
                <img src="/solar-3.jpg" alt="Solaranlage" class="w-full h-full object-cover rounded-2xl" />
            </div>
        </div>

    </div>
</section>
