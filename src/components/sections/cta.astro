---
import { site } from "@/config/site"
---

<section class="w-full bg-background py-28 px-6">
    <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
        <h2>
            Bereit für saubere<br />Energie?
        </h2>
        <p class="text-muted-foreground text-lg max-w-xl mx-auto leading-relaxed mb-12">
            Vereinbaren Sie ein kostenloses Erstgespräch mit unseren Experten
            und erfahren Sie, wie EnergieWelt Ihnen helfen kann.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/offerte" class="btn-primary">Offerte einholen</a>
        </div>
    </div>
</section>
