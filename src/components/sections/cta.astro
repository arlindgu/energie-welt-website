---
import { site } from "@/config/site"
---

<section class="w-full bg-background px-6 py-28">
    <div class="mx-auto max-w-6xl">
        <div class="flex flex-col items-center rounded-[2.5rem] bg-brand-300 px-6 py-20 text-center text-background">
            <h2>
                Wir brauchen diese Veränderung,<br />denn die Zukunft wartet nicht.
            </h2>
            <p class="mx-auto mb-12 max-w-xl text-lg leading-relaxed text-background/80">
                Vereinbaren Sie ein kostenloses Erstgespräch mit unseren Experten
                und erfahren Sie, wie EnergieWelt Ihnen helfen kann.
            </p>
            <div class="flex flex-col justify-center gap-4 sm:flex-row">
                <a href="/offerte" class="btn-white">Offerte einholen</a>
            </div>
        </div>
    </div>
</section>
