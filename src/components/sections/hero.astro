---
import Partners from "./partners.astro"
---

<section
  id="hero"
  class="animated relative flex h-screen w-full flex-col overflow-hidden sm:m-4 sm:h-[calc(100vh-2rem)] sm:w-auto sm:rounded-[2.5rem]"
>
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src="/hero-pic.jpg"
    alt="Solaranlage bei Sonnenuntergang"
  />

  <div
    class="absolute inset-x-0 top-0 h-2/3 bg-black/20 [mask-image:linear-gradient(to_bottom,black,transparent)] backdrop-blur-sm"
  >
  </div>

  <div
    class="relative z-10 mx-auto flex h-full max-w-6xl flex-col items-center justify-center px-6 pt-32 text-center"
  >
    <h1 id="hero-text" class="animated display text-white">
      Sonnenenergie. Ohne Papierkram, ohne Kopfschmerzen.
    </h1>
    <div class="mt-6 flex gap-4">
      <a id="hero-button" href="/offerte" class="animated btn-primary"
        >Offerte einholen</a
      >
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap"

  const title = document.getElementById("hero-text")
  const button = document.getElementById("hero-button")
  const heroSection = document.getElementById("hero")
  const myTimeline = gsap.timeline()

  myTimeline
    .to(heroSection, {
      scale: 1,
      opacity: 1,
      filter: "blur(0px)",
      y: 0,
      duration: 0.5,
      ease: "power2.out",
    })
    .to(title, {
      opacity: 1,
      y: 0,
      filter: "blur(0px)",
      duration: 0.5,
      ease: "power2.out",
    })
    .to(button, {
      opacity: 1,
      y: 0,
      filter: "blur(0px)",
      duration: 0.5,
      ease: "power2.out",
    })
</script>
