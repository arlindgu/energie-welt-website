---
import heroVideo from "@/assets/videos/hero.mp4"
import { Button } from "@/components/ui/button"
---

<section class="w-full mt-16 grid grid-cols-1 lg:grid-cols-2 min-h-screen">

    <div class="flex flex-col justify-center px-8 lg:px-16 py-20 lg:py-0">
        <h1 class="font-heading text-4xl sm:text-5xl xl:text-6xl font-semibold leading-tight mb-6">
            Wir brauchen die Veränderung.<br />
            <span>Wir machen es.</span>
        </h1>
        <p class="text-muted-foreground text-base leading-relaxed mb-10 max-w-sm">
            Nachhaltige Energielösungen für Privat- und Gewerbekunden –
            effizient, zuverlässig und zukunftssicher.
        </p>
        <Button size="xl" className="w-fit">Offerte einholen</Button>
    </div>

    <div class="relative h-64 lg:h-auto overflow-hidden">
        <video
            class="absolute inset-0 w-full h-full object-cover"
            src={heroVideo}
            autoplay
            muted
            loop
            playsinline
        ></video>
    </div>

</section>
