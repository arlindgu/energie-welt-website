---
import heroVideo from "@/assets/videos/hero.mp4"
---

<section
  id="hero"
  class="relative flex h-[calc(100vh-4rem)] w-full flex-col overflow-hidden"
>
  <video
    class="absolute inset-0 h-full w-full object-cover"
    src={heroVideo}
    autoplay
    muted
    playsinline></video>

  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 h-full px-6">
    <div
      class="mx-auto flex h-full max-w-6xl flex-col justify-end pb-12 lg:pb-16"
    >
      <div class="flex items-end justify-between gap-8">
        <div>
          <h1 class="display text-white">
            Wir brauchen die Veränderung.<br />
            <span class="text-brand-300">Wir machen sie.</span>
          </h1>
          <p class="mb-4 max-w-sm text-base leading-relaxed text-white/70">
            Nachhaltige Energielösungen für Privat- und Gewerbekunden –
            effizient, zuverlässig und zukunftssicher.
          </p>
          <a href="/offerte" class="btn-primary">Offerte einholen</a>
        </div>
      </div>
    </div>
  </div>
</section>
