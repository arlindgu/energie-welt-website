---
import heroVideo from "@/assets/videos/hero.mp4"
import Button from "@/components/Button.astro"
---

<section
  class="relative h-[calc(100vh-4rem)] flex w-full flex-col overflow-hidden"
>
  <video
    class="absolute inset-0 h-full w-full object-cover"
    src={heroVideo}
    autoplay
    muted
    playsinline></video>

  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 h-full px-6">
    <div
      class="mx-auto flex h-full max-w-6xl flex-col justify-end pb-12 lg:pb-16"
    >
      <div class="flex items-end justify-between gap-8">
        <div>
          <h1 class="heading-display text-white animate-fade-up">
            Wir brauchen die Veränderung.<br />
            <span class="text-brand">Wir machen sie.</span>
          </h1>
          <p class="mt-4 max-w-sm text-base leading-relaxed text-white/70">
            Nachhaltige Energielösungen für Privat- und Gewerbekunden –
            effizient, zuverlässig und zukunftssicher.
          </p>
        </div>
        <div class="shrink-0">
          <Button variant="primary" href="/offerte">Offerte einholen</Button>
        </div>
      </div>
    </div>
  </div>
</section>
