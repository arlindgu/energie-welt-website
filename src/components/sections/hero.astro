---
import Partners from "./partners.astro"
---

<section
  id="hero"
  class="animated relative flex h-screen w-full flex-col overflow-hidden sm:m-4 sm:h-[calc(100vh-2rem)] sm:w-auto"
>
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src="/hero-pic.png"
    alt="Solaranlage bei Sonnenuntergang"
  />

  <div
    class="absolute h-full w-full blur-sm opacity-50 backdrop-blur-sm"
  >
  </div>

  <div
    class="relative z-10 mx-auto flex h-full max-w-6xl flex-col items-center justify-center px-6 pt-32 text-center"
  >
    <h1 id="hero-text" class="animated display text-steel-100">
      Die Sonne schenkt <span
        class="animate-highlight bg-[linear-gradient(var(--color-brand-300),var(--color-brand-300))] bg-left bg-no-repeat px-2"
        >Leben.</span
      > Wir machen daraus Energie für Ihr Zuhause.
    </h1>
    <div class="mt-6 flex gap-4">
      <a id="hero-primary-button" href="/offerte" class="animated btn-primary"
        >Offerte einholen</a
      >
      <a id="hero-secondary-button" href="/offerte" class="animated btn-secondary"
        >Mehr erfahren</a
      >
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap"

  const title = document.getElementById("hero-text")
  const buttonPrimary = document.getElementById("hero-primary-button")
  const buttonSecondary = document.getElementById("hero-secondary-button")
  const heroSection = document.getElementById("hero")
  const myTimeline = gsap.timeline()

  myTimeline
    .to(heroSection, {
      scale: 1,
      opacity: 1,
      filter: "blur(0px)",
      y: 0,
      duration: 0.5,
      ease: "power2.out",
    })
    .to(title, {
      opacity: 1,
      y: 0,
      filter: "blur(0px)",
      duration: 0.5,
      ease: "power2.out",
    })
    .to(buttonPrimary, {
      opacity: 1,
      y: 0,
      filter: "blur(0px)",
      duration: 0.5,
      ease: "power2.out",
    })
    .to(buttonSecondary, {
      opacity: 1,
      y: 0,
      filter: "blur(0px)",
      duration: 0.5,
      ease: "power2.out",
    })
</script>
