---
import Button from "@/components/Button.astro"
import { Icon } from "astro-icon/components"

const pillars = [
  {
    title: "Zertifizierte Experten",
    description:
      "Unser Team besteht aus geprüften Fachkräften mit langjähriger Erfahrung in erneuerbaren Energien und Gebäudetechnik.",
    icon: "lucide:user-check",
  },
  {
    title: "5 Jahre Garantie",
    description:
      "Auf alle unsere Installationen gewähren wir eine umfassende 5-Jahres-Garantie – für Ihre Sicherheit und unser Qualitätsversprechen.",
    icon: "lucide:shield-check",
  },
  {
    title: "Nachhaltig & zukunftssicher",
    description:
      "Wir planen nicht für heute, sondern für die nächsten Jahrzehnte – mit skalierbaren Lösungen die mit Ihren Anforderungen wachsen.",
    icon: "lucide:leaf",
  },
]
---

<section id="services" class="w-full bg-foreground text-background px-6 py-28">
  <div class="mx-auto flex max-w-6xl flex-col gap-16 xl:flex-row xl:gap-24">
    <div class="mb-16 flex flex-col xl:mb-0">
      <h2
        class="font-heading mb-auto text-7xl leading-tight font-semibold text-background md:text-5xl"
      >
        Qualität und Verlässlichkeit als Grundlage jedes Projekts
      </h2>
      <div>
        <Button href="/kontakt" variant="light"> Jetzt grüner werden </Button>
      </div>
    </div>

    <div class="flex flex-col gap-10">
      {
        pillars.map((item) => (
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-background/10">
              <Icon name={item.icon} class="h-6 w-6 text-background" />
            </div>
            <div>
              <p class="mb-1 text-lg font-bold text-background">
                {item.title}
              </p>
              <p class="text-sm leading-relaxed text-background/70">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
