---
import { Icon } from "astro-icon/components"

const pillars = [
  {
    title: "Zertifizierte Experten",
    description:
      "Unser Team besteht aus geprüften Fachkräften mit langjähriger Erfahrung in erneuerbaren Energien, Speicherlösungen und Gebäudetechnik.",
    icon: "lucide:user-check",
  },
  {
    title: "Sicherheit, die bleibt",
    description:
      "Langfristige Garantieleistungen und fachgerechte Ausführung sichern nachhaltige Qualität. Optionale Wartungsverträge sorgen dafür, dass diese Sicherheit auch langfristig erhalten bleibt.",
    icon: "lucide:shield-check",
  },
  {
    title: "Nachhaltig und zukunftssicher",
    description:
      "Wir planen nicht für heute, sondern für die nächsten Jahrzehnte, mit skalierbaren Lösungen, die mit Ihren Anforderungen wachsen.",
    icon: "lucide:leaf",
  },
]
---

<section id="services" class="w-full bg-foreground text-background px-6 py-28">
  <div class="mx-auto flex max-w-6xl flex-col gap-16 xl:flex-row xl:gap-24">
    <div class="mb-16 flex flex-col xl:mb-0 gap-8">
      <h2
      >
        Qualität und Verlässlichkeit als Grundlage jedes Projekts
      </h2>
      <div>
        <a href="/offerte" class="btn-primary"> Jetzt grüner werden </a>
      </div>
    </div>

    <div class="flex flex-col gap-10">
      {
        pillars.map((item) => (
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center bg-background">
              <Icon name={item.icon} class="h-6 w-6 text-foreground" />
            </div>
            <div>
              <p class="mb-1 text-lg font-bold text-background">
                {item.title}
              </p>
              <p class="text-sm leading-relaxed text-background/70">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
