---
import partner1 from "@/assets/svgs/partners/generics-studio-logo.svg?raw"
import partner2 from "@/assets/svgs/partners/partner-1.svg?raw"
import partner3 from "@/assets/svgs/partners/partner-2.svg?raw"
import partner4 from "@/assets/svgs/partners/partner-3.svg?raw"
import partner5 from "@/assets/svgs/partners/partner-4.svg?raw"
import partner6 from "@/assets/svgs/partners/partner-5.svg?raw"

const partners = [partner1, partner2, partner3, partner4, partner5, partner6]
---

<div class="w-full pb-8">
  <p class="text-center text-xs text-steel-100">Unternehmen, die uns vertrauen</p>

  <div
    class="mt-4 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]"
  >
    <div
      class="flex w-max animate-marquee items-center gap-16 text-steel-100/90 [&_svg]:h-8 [&_svg]:w-auto"
    >
      {[...partners, ...partners].map((logo) => <div set:html={logo} />)}
    </div>
  </div>
</div>
