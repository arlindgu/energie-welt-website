---
import solarIcon from "@/assets/svgs/solar-icon.svg?raw"
import homeIcon from "@/assets/svgs/home-icon.svg?raw"
import computerIcon from "@/assets/svgs/computer.svg?raw"

const content = [
  {
    title: "Erneuerbare Energieanlagen",
    description:
      "Photovoltaik, Wärmepumpen und Speicherlösungen für nachhaltige Energieversorgung.",
    image: "/services-1.jpg",
  },
  {
    title: "Smart Home und Gebäudetechnik",
    description:
      "Intelligente Steuerung von Heizung, Licht und Verbrauch für mehr Effizienz.",
    image: "/services-2.jpg",
  },
  {
    title: "Digitale Lösungen und Plattformen",
    description: "Monitoring und Analyse Ihres Energieverbrauchs in Echtzeit.",
    image: "/services-3.jpg",
  },
]
---

<section class="px-6 py-16">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col items-start justify-between gap-4 lg:flex-row">
      <h2>
        Massgeschneiderte Lösungen.
        <br />
        Für eine nachhaltige Zukunft.
      </h2>
      <p class="max-w-sm">
        Von der Planung bis zum Betrieb bieten wir umfassende Dienstleistungen
        in den Bereichen erneuerbare Energieanlagen, Smart Home und
        Gebäudetechnik sowie digitale Lösungen und Plattformen.
      </p>
    </div>

    <div class="mt-12 flex flex-col gap-4 lg:flex lg:flex-row">
      {
        content.map((item) => (
          <div class="relative h-96 w-full overflow-hidden lg:flex-1">
            <img
              src={item.image}
              alt={item.title}
              class="absolute inset-0 h-full w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent" />
            <div class="absolute right-0 bottom-0 left-0 flex items-end justify-between p-6">
              <div class="flex flex-col gap-3">
                <h3 class="text-2xl text-white">{item.title}</h3>
                <p class="text-white">{item.description}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
