---
import { site } from "@/config/site"

const match = site.address.city.match(/^(\d{4})\s+(.+)$/)
const postalCode = match?.[1] ?? ""
const addressLocality = match?.[2] ?? site.address.city

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${Astro.site}#organization`,
  name: site.legal.company,
  alternateName: site.name,
  description: site.description,
  url: Astro.site?.toString(),
  telephone: site.contact.phone,
  email: site.contact.email,
  image: new URL(site.seo.defaultImage, Astro.site).toString(),
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    postalCode,
    addressLocality,
    addressCountry: "CH",
  },
  areaServed: "CH",
  vatID: site.legal.vatId,
}
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
