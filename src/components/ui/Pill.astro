---
import { Icon } from "astro-icon/components"

interface Props {
  icon: string
  label: string
}

const { icon, label } = Astro.props
---

<span
  class="inline-flex items-center gap-2 bg-background/15 px-4 py-2 text-sm font-medium text-background"
>
  <Icon name={icon} class="h-4 w-4" /> {label}
</span>
