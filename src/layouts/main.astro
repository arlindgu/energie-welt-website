---
import "@/styles/global.css"
import { Font } from "astro:assets"
import { SEO } from "astro-seo"
import Navbar from "@/components/Navbar.astro"
import Footer from "@/components/Footer.astro"
import OrganizationSchema from "@/components/seo/OrganizationSchema.astro"
import { site } from "@/config/site"

interface Props {
  title?: string
  description?: string
  image?: string
  noindex?: boolean
}

const {
  title = site.name,
  description = site.description,
  image = site.seo.defaultImage,
  noindex = false,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const socialImage = new URL(image, Astro.site).toString()
---

<html lang="de-CH">
  <head>
    <Font cssVariable="--font-inter" />
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      openGraph={{
        basic: { title, type: "website", image: socialImage, url: canonicalURL },
        optional: { description, siteName: site.name, locale: "de_CH" },
        image: { alt: title },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        description,
        image: socialImage,
      }}
    />
    <OrganizationSchema />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
