---
import Layout from "@/layouts/main.astro"
import { site } from "@/config/site"
---

<Layout
  title="Impressum | EnergieWelt"
  description="Impressum und rechtliche Angaben der EnergieWelt GmbH gemäss Schweizer Recht."
>
  <section class="px-6 py-32">
    <div class="mx-auto max-w-6xl">
      <h1 class="mb-10 font-heading text-4xl font-semibold">Impressum</h1>

      <div class="flex flex-col gap-8 text-sm leading-relaxed text-foreground">
        <div>
          <h2>Angaben gemäß § 5 TMG</h2>
          <p>
            {site.legal.company}<br />
            {site.address.street}<br />
            {site.address.city}<br />
            {site.address.country}
          </p>
        </div>

        <div>
          <h2>Kontakt</h2>
          <p>
            Telefon: {site.contact.phone}<br />
            E-Mail: {site.contact.email}
          </p>
        </div>

        <div>
          <h2>Umsatzsteuer-ID</h2>
          <p>
            Umsatzsteuer-Identifikationsnummer gemäß § 27a Umsatzsteuergesetz:<br
            />
            {site.legal.vatId}
          </p>
        </div>

        <div>
          <h2>
            Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV
          </h2>
          <p>
            {site.legal.responsible}<br />
            {site.address.street}<br />
            {site.address.city}
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
