---
import Layout from "@/layouts/main.astro"
import { site } from "@/config/site"
---

<Layout>
  <section class="min-h-screen px-6 pt-32 pb-20">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-16 lg:grid-cols-2">
      <div>
        <p
          class="text-muted-foreground mb-3 text-sm font-semibold tracking-wider uppercase"
        >
          Kontakt
        </p>
        <h1
          class="mb-6 font-heading text-4xl leading-tight font-semibold md:text-5xl"
        >
          Wir freuen uns<br />von Ihnen zu hören
        </h1>
        <p class="text-muted-foreground mb-10 max-w-sm leading-relaxed">
          Haben Sie Fragen zu unseren Leistungen? Kontaktieren Sie uns – wir
          melden uns innerhalb von 24 Stunden bei Ihnen.
        </p>

        <div class="flex flex-col gap-6">
          <div>
            <p
              class="text-muted-foreground mb-1 text-xs font-semibold tracking-wider uppercase"
            >
              Dein Ansprechspartner
            </p>
            <a
              href={`mailto:${site.contact.email}`}
              class="hover:text-brand text-foreground transition-colors"
            >
              {site.legal.responsible}
            </a>
          </div>
          <div>
            <p
              class="text-muted-foreground mb-1 text-xs font-semibold tracking-wider uppercase"
            >
              E-Mail
            </p>
            <a
              href={`mailto:${site.contact.email}`}
              class="hover:text-brand text-foreground transition-colors"
            >
              {site.contact.email}
            </a>
          </div>
          <div>
            <p
              class="text-muted-foreground mb-1 text-xs font-semibold tracking-wider uppercase"
            >
              Telefon
            </p>
            <a
              href={site.contact.phoneHref}
              class="hover:text-brand text-foreground transition-colors"
            >
              {site.contact.phone}
            </a>
          </div>
          <div>
            <p
              class="text-muted-foreground mb-1 text-xs font-semibold tracking-wider uppercase"
            >
              Adresse
            </p>
            <p class="text-foreground">
              {site.address.street}<br />{site.address.city}
            </p>
          </div>
        </div>
      </div>

      <div>
        <form id="contact-form" class="flex flex-col gap-5">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Vorname</label>
              <input
                name="vorname"
                type="text"
                placeholder="Max"
                required
                class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Nachname</label>
              <input
                name="nachname"
                type="text"
                placeholder="Mustermann"
                required
                class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
              />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">E-Mail</label>
            <input
              name="email"
              type="email"
              placeholder="max@beispiel.de"
              required
              class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Betreff</label>
            <input
              name="betreff"
              type="text"
              placeholder="Betreff"
              required
              class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Nachricht</label>
            <textarea
              name="nachricht"
              rows="5"
              placeholder="Ihre Nachricht..."
              required
              class="border-border focus:ring-brand/40 resize-none rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
            ></textarea>
          </div>

          <div id="form-feedback" class="hidden rounded-lg px-4 py-3 text-sm">
          </div>

          <button id="submit-btn" class="btn-primary" type="submit"
            ><span id="submit-text">Nachricht senden</span></button
          >
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement
  const btn = document.getElementById("submit-btn") as HTMLButtonElement
  const btnText = document.getElementById("submit-text") as HTMLSpanElement
  const feedback = document.getElementById("form-feedback") as HTMLDivElement

  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    btn.disabled = true
    btnText.textContent = "Wird gesendet..."
    feedback.className = "hidden text-sm rounded-lg px-4 py-3"

    const res = await fetch("/api/contact", {
      method: "POST",
      body: new FormData(form),
    })

    const json = await res.json()

    if (res.ok) {
      feedback.textContent =
        "Ihre Nachricht wurde erfolgreich gesendet. Wir melden uns bald!"
      feedback.className =
        "text-sm rounded-lg px-4 py-3 bg-green-50 text-green-700 border border-green-200"
      form.reset()
    } else {
      feedback.textContent =
        json.error ??
        "Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut."
      feedback.className =
        "text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200"
    }

    btn.disabled = false
    btnText.textContent = "Nachricht senden"
  })
</script>
