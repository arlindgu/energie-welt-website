---
import Layout from "@/layouts/main.astro"
import { Icon } from "astro-icon/components"
---

<Layout>
  <section class="min-h-screen">
    <div class="bg-brand px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <p
          class="mb-3 text-sm font-semibold tracking-wider text-foreground/60 uppercase"
        >
          Kostenlos & unverbindlich
        </p>
        <h1
          class="font-heading text-5xl leading-tight font-semibold text-foreground md:text-6xl"
        >
          Offerte einholen
        </h1>
      </div>
    </div>

    <div class="px-6 py-16">
      <div class="mx-auto grid max-w-6xl grid-cols-1 gap-16 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <form
            id="offerte-form"
            class="flex flex-col gap-10"
            enctype="multipart/form-data"
          >
            <!-- Persönliche Angaben -->
            <div>
              <p
                class="text-muted-foreground mb-5 text-xs font-semibold tracking-widest uppercase"
              >
                Persönliche Angaben
              </p>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Name</label>
                  <input
                    name="name"
                    type="text"
                    placeholder="Max Mustermann"
                    required
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">E-Mail</label>
                  <input
                    name="email"
                    type="email"
                    placeholder="max@beispiel.ch"
                    required
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Telefonnummer</label>
                  <input
                    name="telefon"
                    type="tel"
                    placeholder="+41 00 000 00 00"
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
              </div>
            </div>

            <!-- Objektadresse -->
            <div>
              <p
                class="text-muted-foreground mb-5 text-xs font-semibold tracking-widest uppercase"
              >
                Objektadresse
              </p>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div class="flex flex-col gap-1.5 sm:col-span-3">
                  <label class="text-sm font-medium"
                    >Strasse & Hausnummer</label
                  >
                  <input
                    name="strasse"
                    type="text"
                    placeholder="Musterstrasse 1"
                    required
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">PLZ</label>
                  <input
                    name="plz"
                    type="text"
                    placeholder="8000"
                    required
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Ort</label>
                  <input
                    name="ort"
                    type="text"
                    placeholder="Zürich"
                    required
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Objektzustand</label>
                  <select
                    id="objektzustand"
                    name="objektzustand"
                    required
                    class="border-border focus:ring-brand/40 cursor-pointer rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  >
                    <option value="" disabled selected>Bitte wählen...</option>
                    <option value="Neubau">Neubau</option>
                    <option value="Bestehendes Objekt">Bestehendes Objekt</option>
                    <option value="Erweiterung">Erweiterung</option>
                    <option value="Anderes">Anderes</option>
                  </select>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Gebäudetyp</label>
                  <select
                    name="gebaeude_typ"
                    required
                    class="border-border focus:ring-brand/40 cursor-pointer rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  >
                    <option value="" disabled selected>Bitte wählen...</option>
                    <option value="Einfamilienhaus">Einfamilienhaus</option>
                    <option value="Mehrfamilienhaus">Mehrfamilienhaus</option>
                    <option value="Industrie">Industrie</option>
                  </select>
                </div>
                <div
                  id="objektzustand-anderes-field"
                  class="flex hidden flex-col gap-1.5 sm:col-span-3"
                >
                  <label class="text-sm font-medium"
                    >Objektzustand – bitte beschreiben</label
                  >
                  <input
                    name="objektzustand_anderes"
                    type="text"
                    placeholder="Bitte beschreiben..."
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
              </div>
            </div>

            <!-- Objekt und Projektdetails -->
            <div>
              <p
                class="text-muted-foreground mb-5 text-xs font-semibold tracking-widest uppercase"
              >
                Objekt und Projektdetails
              </p>
              <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Dachtyp</label>
                  <select
                    id="dachtyp"
                    name="dachtyp"
                    required
                    class="border-border focus:ring-brand/40 cursor-pointer rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  >
                    <option value="" disabled selected>Bitte wählen...</option>
                    <option value="Flachdach">Flachdach</option>
                    <option value="Schrägdach">Schrägdach</option>
                    <option value="Anderes">Anderes</option>
                  </select>
                </div>
                <div
                  id="dachtyp-anderes-field"
                  class="flex hidden flex-col gap-1.5"
                >
                  <label class="text-sm font-medium"
                    >Dachtyp – bitte beschreiben</label
                  >
                  <input
                    name="dachtyp_anderes"
                    type="text"
                    placeholder="z.B. Carport, Fassade, ..."
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>

                <div class="flex flex-col gap-2">
                  <label class="text-sm font-medium">Dachart</label>
                  <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                    {
                      ["Renovation", "Neubau", "Sonstiges"].map((art) => (
                        <label class="border-border hover:border-brand/60 has-[:checked]:border-brand has-[:checked]:bg-brand/5 relative flex cursor-pointer items-center gap-3 rounded-lg border px-4 py-3 transition-colors">
                          <input
                            type="radio"
                            name="dachart"
                            value={art}
                            class="accent-brand"
                            required
                          />
                          <span class="text-sm font-medium">{art}</span>
                        </label>
                      ))
                    }
                  </div>
                </div>

                <div id="sonstiges-field" class="flex hidden flex-col gap-1.5">
                  <label class="text-sm font-medium">Bitte beschreiben</label>
                  <input
                    name="dachart_sonstiges"
                    type="text"
                    placeholder="z.B. Flachdach, Carport, ..."
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>

                <div class="flex flex-col gap-1.5">
                  <label class="flex items-center gap-2 text-sm font-medium">
                    Jährlicher Stromverbrauch
                    <span class="text-muted-foreground text-xs font-normal"
                      >(optional)</span
                    >
                  </label>
                  <div class="relative">
                    <input
                      name="verbrauch"
                      type="number"
                      placeholder="3500"
                      min="0"
                      class="border-border focus:ring-brand/40 w-full rounded-lg border bg-background px-4 py-3 pr-16 text-sm focus:ring-2 focus:outline-none"
                    />
                    <span
                      class="text-muted-foreground absolute top-1/2 right-4 -translate-y-1/2 text-sm"
                      >kWh/J</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Anfragedetails -->
            <div>
              <p
                class="text-muted-foreground mb-5 text-xs font-semibold tracking-widest uppercase"
              >
                Anfragedetails
              </p>
              <div class="flex flex-col gap-3">
                {
                  [
                    "PV-Anlage inkl. Wechselrichter",
                    "Batterie",
                    "E-Auto Ladestation",
                    "Verbindung mit Wärmepumpe",
                    "Erweiterung bestehende Anlage",
                  ].map((item) => (
                    <label class="border-border hover:border-brand/60 has-[:checked]:border-brand has-[:checked]:bg-brand/5 flex cursor-pointer items-center gap-3 rounded-lg border px-4 py-3 transition-colors">
                      <input
                        type="checkbox"
                        name="leistungen"
                        value={item}
                        class="accent-brand h-4 w-4"
                      />
                      <span class="text-sm font-medium">{item}</span>
                    </label>
                  ))
                }
                <label
                  class="border-border hover:border-brand/60 has-[:checked]:border-brand has-[:checked]:bg-brand/5 flex cursor-pointer items-center gap-3 rounded-lg border px-4 py-3 transition-colors"
                >
                  <input
                    type="checkbox"
                    id="leistung-sonstiges-cb"
                    name="leistungen"
                    value="Sonstiges"
                    class="accent-brand h-4 w-4"
                  />
                  <span class="text-sm font-medium">Sonstiges</span>
                </label>
                <div
                  id="leistung-sonstiges-field"
                  class="flex hidden flex-col gap-1.5"
                >
                  <label class="text-sm font-medium">Bitte beschreiben</label>
                  <input
                    name="leistungen_sonstiges"
                    type="text"
                    placeholder="Weitere Anforderungen..."
                    class="border-border focus:ring-brand/40 rounded-lg border bg-background px-4 py-3 text-sm focus:ring-2 focus:outline-none"
                  />
                </div>
              </div>
            </div>

            <!-- Anhänge -->
            <div>
              <p
                class="text-muted-foreground mb-5 text-xs font-semibold tracking-widest uppercase"
              >
                Anhänge
              </p>
              <div class="flex flex-col gap-3">
                <label
                  id="upload-label"
                  class="border-border hover:border-brand/60 flex cursor-pointer flex-col items-center justify-center gap-2 rounded-lg border-2 border-dashed px-6 py-8 transition-colors"
                >
                  <Icon
                    name="lucide:upload-cloud"
                    class="h-8 w-8 text-muted-foreground"
                  />
                  <span class="text-sm text-muted-foreground"
                    >PDF-Dateien hier ablegen oder <span
                      class="font-medium text-foreground">auswählen</span
                    ></span
                  >
                  <span class="text-muted-foreground text-xs"
                    >Maximal 10 MB pro Datei</span
                  >
                  <input
                    id="anhaenge"
                    name="anhaenge"
                    type="file"
                    accept=".pdf"
                    multiple
                    class="hidden"
                  />
                </label>
                <div id="file-list" class="flex flex-col gap-2"></div>
              </div>
            </div>

            <div
              id="form-feedback"
              class="hidden rounded-lg px-4 py-3 text-sm"
            >
            </div>

            <button class="btn-primary" id="submit-btn" type="submit"
              ><span id="submit-text">Offerte anfordern</span></button
            >
          </form>
        </div>

        <div class="flex flex-col gap-6">
          <div class="bg-muted flex flex-col gap-5 rounded-2xl p-6">
            <p class="text-sm font-semibold">Was passiert nach der Anfrage?</p>
            {
              [
                {
                  icon: "lucide:phone-call",
                  text: "Wir melden uns innerhalb von 24 Stunden bei Ihnen.",
                },
                {
                  icon: "lucide:calendar-check",
                  text: "Wir vereinbaren einen kostenlosen Vor-Ort-Termin.",
                },
                {
                  icon: "lucide:file-text",
                  text: "Sie erhalten eine detaillierte, unverbindliche Offerte.",
                },
              ].map((step) => (
                <div class="flex items-start gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-background">
                    <Icon name={step.icon} class="h-4 w-4 text-foreground" />
                  </div>
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    {step.text}
                  </p>
                </div>
              ))
            }
          </div>

          <div class="border-border flex flex-col gap-3 rounded-2xl border p-6">
            <p class="text-sm font-semibold">Lieber direkt sprechen?</p>
            <p class="text-muted-foreground flex items-center gap-2 text-sm transition-colors">
              Ihr Ansprechpartner: Liridon Cakolli
            </p>
            <a
              href="tel:++41799278988"
              class="text-muted-foreground flex items-center gap-2 text-sm transition-colors hover:text-foreground"
            >
              <Icon name="lucide:phone" class="h-4 w-4" />
              +41 79 927 89 88
            </a>
            <a
              href="mailto:info@energie-welt.ch"
              class="text-muted-foreground flex items-center gap-2 text-sm transition-colors hover:text-foreground"
            >
              <Icon name="lucide:mail" class="h-4 w-4" />
              info@energie-welt.ch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("offerte-form") as HTMLFormElement
  const btn = document.getElementById("submit-btn") as HTMLButtonElement
  const btnText = document.getElementById("submit-text") as HTMLSpanElement
  const feedback = document.getElementById("form-feedback") as HTMLDivElement

  // Dachart radio → show/hide sonstiges input
  const sontigesField = document.getElementById("sonstiges-field") as HTMLDivElement
  document.querySelectorAll('input[name="dachart"]').forEach((radio) => {
    radio.addEventListener("change", (e) => {
      const val = (e.target as HTMLInputElement).value
      sontigesField.classList.toggle("hidden", val !== "Sonstiges")
    })
  })

  // Objektzustand select → show/hide anderes input
  const objektzustandSelect = document.getElementById("objektzustand") as HTMLSelectElement
  const objektzustandAnderesField = document.getElementById("objektzustand-anderes-field") as HTMLDivElement
  objektzustandSelect.addEventListener("change", () => {
    objektzustandAnderesField.classList.toggle("hidden", objektzustandSelect.value !== "Anderes")
  })

  // Dachtyp select → show/hide anderes input
  const dachtypSelect = document.getElementById("dachtyp") as HTMLSelectElement
  const dachtypAnderesField = document.getElementById("dachtyp-anderes-field") as HTMLDivElement
  dachtypSelect.addEventListener("change", () => {
    dachtypAnderesField.classList.toggle("hidden", dachtypSelect.value !== "Anderes")
  })

  // Leistungen sonstiges checkbox → show/hide input
  const leistungSonstigesCb = document.getElementById("leistung-sonstiges-cb") as HTMLInputElement
  const leistungSonstigesField = document.getElementById("leistung-sonstiges-field") as HTMLDivElement
  leistungSonstigesCb.addEventListener("change", () => {
    leistungSonstigesField.classList.toggle("hidden", !leistungSonstigesCb.checked)
  })

  // File upload → show selected filenames
  const fileInput = document.getElementById("anhaenge") as HTMLInputElement
  const fileList = document.getElementById("file-list") as HTMLDivElement
  fileInput.addEventListener("change", () => {
    fileList.innerHTML = ""
    Array.from(fileInput.files ?? []).forEach((file) => {
      const el = document.createElement("div")
      el.className = "flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm"
      el.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span class="truncate">${file.name}</span><span class="ml-auto shrink-0 text-muted-foreground">${(file.size / 1024 / 1024).toFixed(1)} MB</span>`
      fileList.appendChild(el)
    })
  })

  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    btn.disabled = true
    btnText.textContent = "Wird gesendet..."
    feedback.className = "hidden text-sm rounded-lg px-4 py-3"

    const res = await fetch("/api/offerte", {
      method: "POST",
      body: new FormData(form),
    })

    const json = await res.json()

    if (res.ok) {
      feedback.textContent =
        "Ihre Anfrage wurde erfolgreich gesendet. Wir melden uns bald!"
      feedback.className =
        "text-sm rounded-lg px-4 py-3 bg-green-50 text-green-700 border border-green-200"
      form.reset()
      sontigesField.classList.add("hidden")
      objektzustandAnderesField.classList.add("hidden")
      dachtypAnderesField.classList.add("hidden")
      leistungSonstigesField.classList.add("hidden")
      fileList.innerHTML = ""
    } else {
      feedback.textContent =
        json.error ??
        "Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut."
      feedback.className =
        "text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200"
    }

    btn.disabled = false
    btnText.textContent = "Offerte anfordern"
  })
</script>
