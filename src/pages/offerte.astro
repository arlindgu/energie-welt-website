---
import Layout from "@/layouts/main.astro"
import Button from "@/components/Button.astro"
import { Icon } from "astro-icon/components"
---

<Layout>
  <section class="min-h-screen">

    <div class="bg-brand px-6 py-16">
      <div class="max-w-6xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-wider text-foreground/60 mb-3">Kostenlos & unverbindlich</p>
        <h1 class="font-heading text-5xl md:text-6xl font-semibold leading-tight text-foreground">
          Offerte einholen
        </h1>
      </div>
    </div>

    <div class="px-6 py-16">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

        <div class="lg:col-span-2">
          <form id="offerte-form" class="flex flex-col gap-10">

            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5">Persönliche Angaben</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Name</label>
                  <input name="name" type="text" placeholder="Max Mustermann" required class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">E-Mail</label>
                  <input name="email" type="email" placeholder="max@beispiel.ch" required class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Telefonnummer</label>
                  <input name="telefon" type="tel" placeholder="+41 00 000 00 00" class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>
              </div>
            </div>

            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5">Objektadresse</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="flex flex-col gap-1.5 sm:col-span-3">
                  <label class="text-sm font-medium">Strasse & Hausnummer</label>
                  <input name="strasse" type="text" placeholder="Musterstrasse 1" required class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">PLZ</label>
                  <input name="plz" type="text" placeholder="8000" required class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Ort</label>
                  <input name="ort" type="text" placeholder="Zürich" required class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>
              </div>
            </div>

            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5">Projektdetails</p>
              <div class="flex flex-col gap-4">

                <div class="flex flex-col gap-2">
                  <label class="text-sm font-medium">Dachart</label>
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    {["Renovation", "Neubau", "Sonstiges"].map((art) => (
                      <label class="relative flex items-center gap-3 border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-brand/60 has-[:checked]:border-brand has-[:checked]:bg-brand/5 transition-colors">
                        <input type="radio" name="dachart" value={art} class="accent-brand" required />
                        <span class="text-sm font-medium">{art}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div id="sonstiges-field" class="hidden flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Bitte beschreiben</label>
                  <input name="dachart_sonstiges" type="text" placeholder="z.B. Flachdach, Carport, ..." class="border border-border rounded-lg px-4 py-3 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40" />
                </div>

                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium flex items-center gap-2">
                    Jährlicher Stromverbrauch
                    <span class="text-xs text-muted-foreground font-normal">(optional)</span>
                  </label>
                  <div class="relative">
                    <input name="verbrauch" type="number" placeholder="3500" min="0" class="border border-border rounded-lg px-4 py-3 pr-16 text-sm bg-background focus:outline-none focus:ring-2 focus:ring-brand/40 w-full" />
                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-muted-foreground">kWh/J</span>
                  </div>
                </div>

              </div>
            </div>

            <div id="form-feedback" class="hidden text-sm rounded-lg px-4 py-3"></div>

            <Button id="submit-btn" type="submit"><span id="submit-text">Offerte anfordern</span></Button>

          </form>
        </div>

        <div class="flex flex-col gap-6">
          <div class="bg-muted rounded-2xl p-6 flex flex-col gap-5">
            <p class="font-semibold text-sm">Was passiert nach der Anfrage?</p>
            {[
              { icon: "lucide:phone-call", text: "Wir melden uns innerhalb von 24 Stunden bei Ihnen." },
              { icon: "lucide:calendar-check", text: "Wir vereinbaren einen kostenlosen Vor-Ort-Termin." },
              { icon: "lucide:file-text", text: "Sie erhalten eine detaillierte, unverbindliche Offerte." },
            ].map((step) => (
              <div class="flex gap-3 items-start">
                <div class="shrink-0 w-8 h-8 rounded-lg bg-background flex items-center justify-center">
                  <Icon name={step.icon} class="w-4 h-4 text-foreground" />
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">{step.text}</p>
              </div>
            ))}
          </div>

          <div class="rounded-2xl border border-border p-6 flex flex-col gap-3">
            <p class="font-semibold text-sm">Lieber direkt sprechen?</p>
            <a href="tel:+41000000000" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
              <Icon name="lucide:phone" class="w-4 h-4" />
              +41 00 000 00 00
            </a>
            <a href="mailto:info@energie-welt.ch" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
              <Icon name="lucide:mail" class="w-4 h-4" />
              info@energie-welt.ch
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("offerte-form") as HTMLFormElement
  const btn = document.getElementById("submit-btn") as HTMLButtonElement
  const btnText = document.getElementById("submit-text") as HTMLSpanElement
  const feedback = document.getElementById("form-feedback") as HTMLDivElement
  const sontigesField = document.getElementById("sonstiges-field") as HTMLDivElement

  document.querySelectorAll('input[name="dachart"]').forEach((radio) => {
    radio.addEventListener("change", (e) => {
      const val = (e.target as HTMLInputElement).value
      sontigesField.classList.toggle("hidden", val !== "Sonstiges")
    })
  })

  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    btn.disabled = true
    btnText.textContent = "Wird gesendet..."
    feedback.className = "hidden text-sm rounded-lg px-4 py-3"

    const res = await fetch("/api/offerte", {
      method: "POST",
      body: new FormData(form),
    })

    const json = await res.json()

    if (res.ok) {
      feedback.textContent = "Ihre Anfrage wurde erfolgreich gesendet. Wir melden uns bald!"
      feedback.className = "text-sm rounded-lg px-4 py-3 bg-green-50 text-green-700 border border-green-200"
      form.reset()
      sontigesField.classList.add("hidden")
    } else {
      feedback.textContent = json.error ?? "Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut."
      feedback.className = "text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200"
    }

    btn.disabled = false
    btnText.textContent = "Offerte anfordern"
  })
</script>
