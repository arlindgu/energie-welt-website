---
import Layout from "@/layouts/main.astro"
import { Icon } from "astro-icon/components"
---

<Layout>
  <section class="min-h-screen">
    <div class="relative overflow-hidden bg-brand-300 px-6 pt-40 pb-20 sm:pt-48 sm:pb-24">
      <Icon
        name="lucide:sun"
        class="pointer-events-none absolute -top-16 -right-16 h-72 w-72 text-brand-950/10 sm:h-96 sm:w-96"
      />

      <div class="relative mx-auto max-w-6xl">
        <h1
          class="font-heading text-5xl leading-tight font-semibold text-background md:text-6xl"
        >
          Offerte einholen
        </h1>
        <p class="mt-4 max-w-xl text-lg leading-relaxed text-background/80">
          Erzählen Sie uns von Ihrem Projekt – wir melden uns innerhalb von
          24 Stunden mit einer unverbindlichen Offerte.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <span
            class="inline-flex items-center gap-2 rounded-full bg-background/15 px-4 py-2 text-sm font-medium text-background"
          >
            <Icon name="lucide:circle-check" class="h-4 w-4" /> Kostenlos
          </span>
          <span
            class="inline-flex items-center gap-2 rounded-full bg-background/15 px-4 py-2 text-sm font-medium text-background"
          >
            <Icon name="lucide:circle-check" class="h-4 w-4" /> Unverbindlich
          </span>
          <span
            class="inline-flex items-center gap-2 rounded-full bg-background/15 px-4 py-2 text-sm font-medium text-background"
          >
            <Icon name="lucide:clock" class="h-4 w-4" /> Antwort in 24 Std.
          </span>
        </div>
      </div>
    </div>

    <div class="px-6 py-16">
      <div class="mx-auto grid max-w-6xl grid-cols-1 gap-16 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <form
            id="offerte-form"
            class="flex flex-col gap-10"
            enctype="multipart/form-data"
          >
            <!-- Persönliche Angaben -->
            <div class="rounded-2xl border border-border bg-muted p-6 sm:p-8">
              <div class="mb-6 flex items-center gap-2.5">
                <Icon name="lucide:user" class="text-brand h-5 w-5" />
                <p class="text-lg font-semibold text-foreground">
                  Persönliche Angaben
                </p>
              </div>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Name</label>
                  <input
                    name="name"
                    type="text"
                    placeholder="Max Mustermann"
                    required
                    class="input-field"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">E-Mail</label>
                  <input
                    name="email"
                    type="email"
                    placeholder="max@beispiel.ch"
                    required
                    class="input-field"
                  />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Telefonnummer</label>
                  <input
                    name="telefon"
                    type="tel"
                    placeholder="+41 00 000 00 00"
                    class="input-field"
                  />
                </div>
              </div>
            </div>

            <!-- Objektadresse -->
            <div class="rounded-2xl border border-border bg-muted p-6 sm:p-8">
              <div class="mb-6 flex items-center gap-2.5">
                <Icon name="lucide:map-pin" class="text-brand h-5 w-5" />
                <p class="text-lg font-semibold text-foreground">
                  Objektadresse
                </p>
              </div>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div class="relative flex flex-col gap-1.5 sm:col-span-3">
                  <label class="text-sm font-medium"
                    >Strasse und Hausnummer</label
                  >
                  <input
                    id="strasse"
                    name="strasse"
                    type="text"
                    placeholder="Musterstrasse 1"
                    autocomplete="off"
                    required
                    class="input-field"
                  />
                  <div
                    id="strasse-suggestions"
                    class="border-border absolute top-full right-0 left-0 z-20 mt-1 hidden max-h-64 overflow-y-auto rounded-lg border bg-background shadow-lg"
                  >
                  </div>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">PLZ</label>
                  <input
                    id="plz"
                    name="plz"
                    type="text"
                    placeholder="8000"
                    required
                    class="input-field"
                  />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Ort</label>
                  <input
                    id="ort"
                    name="ort"
                    type="text"
                    placeholder="Zürich"
                    required
                    class="input-field"
                  />
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-2">
                  <label class="text-sm font-medium">Objektzustand</label>
                  <select
                    id="objektzustand"
                    name="objektzustand"
                    required
                    class="input-field cursor-pointer"
                  >
                    <option value="" disabled selected>Bitte wählen...</option>
                    <option value="Neubau">Neubau</option>
                    <option value="Bestehendes Objekt">Bestehendes Objekt</option>
                    <option value="Erweiterung">Erweiterung</option>
                    <option value="Anderes">Anderes</option>
                  </select>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Gebäudetyp</label>
                  <select
                    name="gebaeude_typ"
                    required
                    class="input-field cursor-pointer"
                  >
                    <option value="" disabled selected>Bitte wählen...</option>
                    <option value="Einfamilienhaus">Einfamilienhaus</option>
                    <option value="Mehrfamilienhaus">Mehrfamilienhaus</option>
                    <option value="Industrie">Industrie</option>
                  </select>
                </div>
                <div
                  id="objektzustand-anderes-field"
                  class="flex hidden flex-col gap-1.5 sm:col-span-3"
                >
                  <label class="text-sm font-medium"
                    >Objektzustand – bitte beschreiben</label
                  >
                  <input
                    name="objektzustand_anderes"
                    type="text"
                    placeholder="Bitte beschreiben..."
                    class="input-field"
                  />
                </div>
              </div>
            </div>

            <!-- Objekt und Projektdetails -->
            <div class="rounded-2xl border border-border bg-muted p-6 sm:p-8">
              <div class="mb-6 flex items-center gap-2.5">
                <Icon name="lucide:house" class="text-brand h-5 w-5" />
                <p class="text-lg font-semibold text-foreground">
                  Objekt und Projektdetails
                </p>
              </div>
              <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Dachtyp</label>
                  <select
                    id="dachtyp"
                    name="dachtyp"
                    required
                    class="input-field cursor-pointer"
                  >
                    <option value="" disabled selected>Bitte wählen...</option>
                    <option value="Flachdach">Flachdach</option>
                    <option value="Schrägdach">Schrägdach</option>
                    <option value="Anderes">Anderes</option>
                  </select>
                </div>
                <div
                  id="dachtyp-anderes-field"
                  class="flex hidden flex-col gap-1.5"
                >
                  <label class="text-sm font-medium"
                    >Dachtyp – bitte beschreiben</label
                  >
                  <input
                    name="dachtyp_anderes"
                    type="text"
                    placeholder="z.B. Carport, Fassade, ..."
                    class="input-field"
                  />
                </div>

                <div class="flex flex-col gap-1.5">
                  <label class="flex items-center gap-2 text-sm font-medium">
                    Jährlicher Stromverbrauch
                    <span class="text-muted-foreground text-xs font-normal"
                      >(optional)</span
                    >
                  </label>
                  <div class="relative">
                    <input
                      name="verbrauch"
                      type="number"
                      placeholder="3500"
                      min="0"
                      class="input-field pr-16"
                    />
                    <span
                      class="text-muted-foreground absolute top-1/2 right-4 -translate-y-1/2 text-sm"
                      >kWh/J</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Anfragedetails -->
            <div class="rounded-2xl border border-border bg-muted p-6 sm:p-8">
              <div class="mb-6 flex items-center gap-2.5">
                <Icon name="lucide:list-checks" class="text-brand h-5 w-5" />
                <p class="text-lg font-semibold text-foreground">
                  Anfragedetails
                </p>
              </div>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                {
                  [
                    "PV-Anlage inkl. Wechselrichter",
                    "Batterie",
                    "E-Auto Ladestation",
                    "Energiemanagementsystem (Verbindung mit Wärmepumpe / Boiler)",
                    "Erweiterung bestehende Anlage",
                    "Wartung und Support",
                    "Ausschliesslich Energieberatung",
                  ].map((item) => (
                    <label class="checkbox-card">
                      <input
                        type="checkbox"
                        name="leistungen"
                        value={item}
                        class="accent-brand h-4 w-4"
                      />
                      <span class="text-sm font-medium">{item}</span>
                    </label>
                  ))
                }
                <label
                  class="checkbox-card"
                >
                  <input
                    type="checkbox"
                    id="leistung-sonstiges-cb"
                    name="leistungen"
                    value="Sonstiges"
                    class="accent-brand h-4 w-4"
                  />
                  <span class="text-sm font-medium">Sonstiges</span>
                </label>
                <div
                  id="leistung-sonstiges-field"
                  class="flex hidden flex-col gap-1.5 sm:col-span-2"
                >
                  <label class="text-sm font-medium">Bitte beschreiben</label>
                  <input
                    name="leistungen_sonstiges"
                    type="text"
                    placeholder="Weitere Anforderungen..."
                    class="input-field"
                  />
                </div>
              </div>
            </div>

            <!-- Anhänge -->
            <div class="rounded-2xl border border-border bg-muted p-6 sm:p-8">
              <div class="mb-6 flex items-center gap-2.5">
                <Icon name="lucide:paperclip" class="text-brand h-5 w-5" />
                <p class="text-lg font-semibold text-foreground">
                  Anhänge
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <div class="flex flex-col gap-1.5">
                  <label class="text-sm font-medium">Art des Anhangs</label>
                  <select
                    id="anhang-typ"
                    name="anhang_typ"
                    class="input-field cursor-pointer"
                  >
                    <option value="" selected>Bitte wählen...</option>
                    <option value="Allgemeine Gebäudepläne"
                      >Allgemeine Gebäudepläne</option
                    >
                    <option value="Dachpläne">Dachpläne</option>
                    <option value="Ausschreibung">Ausschreibung</option>
                    <option value="Sonstiges">Sonstiges</option>
                  </select>
                </div>
                <div
                  id="anhang-typ-anderes-field"
                  class="flex hidden flex-col gap-1.5"
                >
                  <label class="text-sm font-medium"
                    >Art des Anhangs – bitte beschreiben</label
                  >
                  <input
                    name="anhang_typ_sonstiges"
                    type="text"
                    placeholder="Bitte beschreiben..."
                    class="input-field"
                  />
                </div>

                <label
                  id="upload-label"
                  class="upload-dropzone"
                >
                  <Icon
                    name="lucide:upload-cloud"
                    class="h-8 w-8 text-muted-foreground"
                  />
                  <span class="text-sm text-muted-foreground"
                    >PDF-Dateien hier ablegen oder <span
                      class="font-medium text-foreground">auswählen</span
                    ></span
                  >
                  <span class="text-muted-foreground text-xs"
                    >Maximal 10 MB pro Datei</span
                  >
                  <input
                    id="anhaenge"
                    name="anhaenge"
                    type="file"
                    accept=".pdf"
                    multiple
                    class="hidden"
                  />
                </label>
                <div id="file-list" class="flex flex-col gap-2"></div>
              </div>
            </div>

            <div
              id="form-feedback"
              class="hidden rounded-lg px-4 py-3 text-sm"
            >
            </div>

            <button class="btn-primary" id="submit-btn" type="submit"
              ><span id="submit-text">Offerte anfordern</span></button
            >
          </form>
        </div>

        <div class="flex flex-col gap-6">
          <div class="border-border bg-muted flex flex-col gap-5 rounded-2xl border p-6">
            <p class="text-sm font-semibold">Was passiert nach der Anfrage?</p>
            {
              [
                {
                  icon: "lucide:phone-call",
                  text: "Wir melden uns innerhalb von 24 Stunden bei Ihnen.",
                },
                {
                  icon: "lucide:calendar-check",
                  text: "Wir vereinbaren einen kostenlosen Vor-Ort-Termin.",
                },
                {
                  icon: "lucide:file-text",
                  text: "Sie erhalten eine detaillierte, unverbindliche Offerte.",
                },
              ].map((step) => (
                <div class="flex items-start gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-background">
                    <Icon name={step.icon} class="h-4 w-4 text-foreground" />
                  </div>
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    {step.text}
                  </p>
                </div>
              ))
            }
          </div>

          <div class="border-border flex flex-col gap-3 rounded-2xl border p-6">
            <p class="text-sm font-semibold">Lieber direkt sprechen?</p>
            <p
            class="text-muted-foreground flex items-center gap-2 text-sm transition-colors hover:text-foreground"
            >
            <Icon name="lucide:user-round-pen" class="h-4 w-4" />
              Liridon Cakolli
            </p>
            <a
              href="tel:++41799278988"
              class="text-muted-foreground flex items-center gap-2 text-sm transition-colors hover:text-foreground"
            >
              <Icon name="lucide:phone" class="h-4 w-4" />
              +41 79 927 89 88
            </a>
            <a
              href="mailto:info@energie-welt.ch"
              class="text-muted-foreground flex items-center gap-2 text-sm transition-colors hover:text-foreground"
            >
              <Icon name="lucide:mail" class="h-4 w-4" />
              info@energie-welt.ch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("offerte-form") as HTMLFormElement
  const btn = document.getElementById("submit-btn") as HTMLButtonElement
  const btnText = document.getElementById("submit-text") as HTMLSpanElement
  const feedback = document.getElementById("form-feedback") as HTMLDivElement

  // Objektzustand select → show/hide anderes input
  const objektzustandSelect = document.getElementById("objektzustand") as HTMLSelectElement
  const objektzustandAnderesField = document.getElementById("objektzustand-anderes-field") as HTMLDivElement
  objektzustandSelect.addEventListener("change", () => {
    objektzustandAnderesField.classList.toggle("hidden", objektzustandSelect.value !== "Anderes")
  })

  // Dachtyp select → show/hide anderes input
  const dachtypSelect = document.getElementById("dachtyp") as HTMLSelectElement
  const dachtypAnderesField = document.getElementById("dachtyp-anderes-field") as HTMLDivElement
  dachtypSelect.addEventListener("change", () => {
    dachtypAnderesField.classList.toggle("hidden", dachtypSelect.value !== "Anderes")
  })

  // Leistungen sonstiges checkbox → show/hide input
  const leistungSonstigesCb = document.getElementById("leistung-sonstiges-cb") as HTMLInputElement
  const leistungSonstigesField = document.getElementById("leistung-sonstiges-field") as HTMLDivElement
  leistungSonstigesCb.addEventListener("change", () => {
    leistungSonstigesField.classList.toggle("hidden", !leistungSonstigesCb.checked)
  })

  // Anhang-Typ select → show/hide anderes input
  const anhangTypSelect = document.getElementById("anhang-typ") as HTMLSelectElement
  const anhangTypAnderesField = document.getElementById("anhang-typ-anderes-field") as HTMLDivElement
  anhangTypSelect.addEventListener("change", () => {
    anhangTypAnderesField.classList.toggle("hidden", anhangTypSelect.value !== "Sonstiges")
  })

  // Strasse-Autocomplete via geo.admin.ch (Swiss address search, keyless public API)
  const strasseInput = document.getElementById("strasse") as HTMLInputElement
  const plzInput = document.getElementById("plz") as HTMLInputElement
  const ortInput = document.getElementById("ort") as HTMLInputElement
  const suggestionsBox = document.getElementById("strasse-suggestions") as HTMLDivElement
  let suggestionsDebounce: ReturnType<typeof setTimeout>

  function hideSuggestions() {
    suggestionsBox.classList.add("hidden")
    suggestionsBox.innerHTML = ""
  }

  strasseInput.addEventListener("input", () => {
    const query = strasseInput.value.trim()
    clearTimeout(suggestionsDebounce)

    if (query.length < 3) {
      hideSuggestions()
      return
    }

    suggestionsDebounce = setTimeout(async () => {
      const url = `https://api3.geo.admin.ch/rest/services/api/SearchServer?searchText=${encodeURIComponent(query)}&type=locations&origins=address&limit=8`
      const res = await fetch(url)
      if (!res.ok) return
      const json = await res.json()
      const results = (json.results ?? []) as { attrs: { label: string } }[]

      if (!results.length) {
        hideSuggestions()
        return
      }

      suggestionsBox.innerHTML = ""
      results.forEach(({ attrs }) => {
        const plainLabel = attrs.label.replace(/<[^>]+>/g, "")
        const item = document.createElement("button")
        item.type = "button"
        item.className = "hover:bg-muted block w-full px-4 py-2.5 text-left text-sm"
        item.textContent = plainLabel
        item.addEventListener("click", () => {
          const match = plainLabel.match(/^(.*?)\s+(\d{4})\s+(.+)$/)
          if (match) {
            strasseInput.value = match[1]
            plzInput.value = match[2]
            ortInput.value = match[3]
          }
          hideSuggestions()
        })
        suggestionsBox.appendChild(item)
      })
      suggestionsBox.classList.remove("hidden")
    }, 300)
  })

  document.addEventListener("click", (e) => {
    if (!suggestionsBox.contains(e.target as Node) && e.target !== strasseInput) {
      hideSuggestions()
    }
  })

  strasseInput.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hideSuggestions()
  })

  // File upload → show selected filenames
  const fileInput = document.getElementById("anhaenge") as HTMLInputElement
  const fileList = document.getElementById("file-list") as HTMLDivElement
  fileInput.addEventListener("change", () => {
    fileList.innerHTML = ""
    Array.from(fileInput.files ?? []).forEach((file) => {
      const el = document.createElement("div")
      el.className = "flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm"
      el.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span class="truncate">${file.name}</span><span class="ml-auto shrink-0 text-muted-foreground">${(file.size / 1024 / 1024).toFixed(1)} MB</span>`
      fileList.appendChild(el)
    })
  })

  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    btn.disabled = true
    btnText.textContent = "Wird gesendet..."
    feedback.className = "hidden text-sm rounded-lg px-4 py-3"

    const res = await fetch("/api/offerte", {
      method: "POST",
      body: new FormData(form),
    })

    const json = await res.json()

    if (res.ok) {
      feedback.textContent =
        "Ihre Anfrage wurde erfolgreich gesendet. Wir melden uns bald!"
      feedback.className =
        "text-sm rounded-lg px-4 py-3 bg-brand-50 text-brand-800 border border-brand-100"
      form.reset()
      objektzustandAnderesField.classList.add("hidden")
      dachtypAnderesField.classList.add("hidden")
      leistungSonstigesField.classList.add("hidden")
      anhangTypAnderesField.classList.add("hidden")
      hideSuggestions()
      fileList.innerHTML = ""
    } else {
      feedback.textContent =
        json.error ??
        "Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut."
      feedback.className =
        "text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200"
    }

    btn.disabled = false
    btnText.textContent = "Offerte anfordern"
  })
</script>
